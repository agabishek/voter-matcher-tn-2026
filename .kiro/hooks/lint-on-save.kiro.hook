{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on the voter-matcher project whenever a TypeScript or TSX file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "voter-matcher/**/*.ts",
      "voter-matcher/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd voter-matcher && npm run lint"
  }
}